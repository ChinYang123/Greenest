---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import MockForm from '../../components/MockForm.astro';
import { getLangFromUrl, useTranslations, langStaticPaths } from '../../i18n/utils';

export const getStaticPaths = langStaticPaths;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const fields = [
  { name: 'name', label: t('form.name'), type: 'text' as const, required: true },
  { name: 'email', label: t('form.email'), type: 'email' as const, required: true },
  { name: 'phone', label: t('form.phone'), type: 'tel' as const, required: true },
  { name: 'community', label: t('form.community'), type: 'text' as const, required: true },
  { name: 'units', label: t('form.units'), type: 'text' as const, required: false },
  { name: 'message', label: t('form.message'), type: 'textarea' as const, required: false },
];

const steps = [
  { icon: 'map', title: t('community.step1Title'), desc: t('community.step1Desc') },
  { icon: 'hammer', title: t('community.step2Title'), desc: t('community.step2Desc') },
  { icon: 'graduation-cap', title: t('community.step3Title'), desc: t('community.step3Desc') },
];

const evidence = lang === 'zh'
  ? [
      { value: '66%', label: '对社区园艺项目感兴趣' },
      { value: '82%', label: '认同家庭绿地改善心理健康和生活质量' },
      { value: '88%', label: '重视环保和可持续材料' },
    ]
  : [
      { value: '66%', label: 'Interested in community gardening projects' },
      { value: '82%', label: 'Agree home greenery improves mental well-being and quality of life' },
      { value: '88%', label: 'Consider eco-friendly materials important' },
    ];

const outcomes = lang === 'zh'
  ? [
      { icon: 'users', title: '建立邻里参与', desc: '把城市居民对社区活动的兴趣转化为共享种植计划。' },
      { icon: 'sprout', title: '共享可食用与观赏植物', desc: '支持受访者对食用和装饰植物的混合偏好。' },
      { icon: 'book-open', title: '工作坊与维护支持', desc: '通过培训降低新手的知识缺口和维护压力。' },
    ]
  : [
      { icon: 'users', title: 'Build resident participation', desc: 'Turns interest in community activity into a shared planting program.' },
      { icon: 'sprout', title: 'Shared edible and decorative planting', desc: 'Supports the mixed edible/decorative plant preferences found in the survey.' },
      { icon: 'book-open', title: 'Workshops and maintenance support', desc: 'Training reduces beginner knowledge gaps and ongoing maintenance stress.' },
    ];
---
<BaseLayout title={t('community.title')} description={t('community.subtitle')}>
  <PageHeader title={t('community.heroTitle')} subtitle={t('community.heroDesc')} />

  <section>
    <div class="container">
      <SectionHeader
        title={lang === 'zh' ? '为什么社区花园符合调研结果' : 'Why community gardens fit the research'}
        subtitle={lang === 'zh'
          ? 'Entrepreneurship.docx 显示，社区参与、心理健康与可持续生活是 CityGarden 的重要定位。'
          : 'Entrepreneurship.docx shows that community participation, well-being, and sustainable living are important parts of CityGarden’s positioning.'}
      />
      <div class="grid grid-3">
        {evidence.map((item) => (
          <div class="feature-card">
            <div class="stat-value" style="color:var(--primary);">{item.value}</div>
            <h3>{item.label}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section--surface">
    <div class="container">
      <SectionHeader title={t('community.title')} subtitle={t('community.subtitle')} />
      <div class="grid grid-3">
        {steps.map((s) => (
          <div class="feature-card text-center">
            <div class="icon-wrapper" style="margin: 0 auto 1.5rem;"><i data-lucide={s.icon}></i></div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <SectionHeader
        title={lang === 'zh' ? '项目带来的价值' : 'Program Value'}
        subtitle={lang === 'zh'
          ? '这个页面展示 CityGarden 如何把报告中的社区园艺机会转化为可执行服务。'
          : 'This page shows how CityGarden turns the report’s community-gardening opportunity into an actionable service.'}
      />
      <div class="grid grid-3">
        {outcomes.map((o) => (
          <div class="feature-card">
            <div class="icon-wrapper"><i data-lucide={o.icon}></i></div>
            <h3>{o.title}</h3>
            <p>{o.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section--surface">
    <div class="container" style="max-width: 680px;">
      <MockForm title={t('community.formTitle')} fields={fields} submitLabel={t('btn.register')} />
    </div>
  </section>
</BaseLayout>
