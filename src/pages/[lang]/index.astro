---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, langStaticPaths } from '../../i18n/utils';
import { products } from '../../data/products';

export const getStaticPaths = langStaticPaths;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const problems = [
  { icon: 'layout-grid', title: t('home.problem1Title'), desc: t('home.problem1Desc') },
  { icon: 'sprout', title: t('home.problem2Title'), desc: t('home.problem2Desc') },
  { icon: 'droplet', title: t('home.problem3Title'), desc: t('home.problem3Desc') },
];
const benefits = [
  { icon: 'globe', title: t('home.benefit1Title'), desc: t('home.benefit1Desc') },
  { icon: 'cpu', title: t('home.benefit2Title'), desc: t('home.benefit2Desc') },
  { icon: 'pen-tool', title: t('home.benefit3Title'), desc: t('home.benefit3Desc') },
  { icon: 'users', title: t('home.benefit4Title'), desc: t('home.benefit4Desc') },
];
const testimonials = lang === 'zh'
  ? [
      { initial: 'NF', name: '诺菲祖尔·阿兹米', role: 'Mont Kiara 公寓业主', quote: '“我住 21 楼，一直以为养不了什么植物。Smart Garden Kit 的土壤传感器改变了一切——现在我每周能收获满满一碗沙拉，邻居都来问我是怎么做到的。”' },
      { initial: 'CT', name: '陈家慧', role: 'The Social Cup 咖啡馆创始人，八打灵再也', quote: '“屋顶原本是烫得没法用的空间。GreenNest 做完结构评估并完成安装后，我们菜单上有 6 样自产食材，每月至少省下 RM 1,400 的食材成本。”' },
      { initial: 'RS', name: '罗希尼·苏布拉马尼亚', role: '安邦 PPR 公寓居委会负责人', quote: '“Siti 和她的团队在两个周末把我们楼下空地变成了真正的社区菜园。现在超过 40 户家庭在这里种菜，孩子们终于知道蔬菜是怎么长出来的了。”' },
    ]
  : [
      { initial: 'NF', name: 'Norfizul Azmi', role: 'Apartment Owner, Mont Kiara KL', quote: '“I live on the 21st floor and assumed gardening was impossible. The Smart Kit soil sensor changed everything — I harvest a full salad bowl every week and my neighbours keep asking how I do it.”' },
      { initial: 'CT', name: 'Cheryl Tan', role: 'Founder, The Social Cup Café, PJ', quote: '“Our rooftop was just wasted heat. After GreenNest\'s structural check and full install, we have 6 menu ingredients grown upstairs and save at least RM 1,400 in produce costs every month.”' },
      { initial: 'RS', name: 'Rohini Subramaniam', role: 'Residents Committee Chair, PPR Ampang', quote: '“Siti\'s team turned our unused ground-floor plot into a real community garden in two weekends. Over 40 households grow here now, and the kids finally know where vegetables come from.”' },
    ];
const designPath = getLocalizedPath('/design-your-garden', lang);
const productsPath = getLocalizedPath('/products', lang);
---
<BaseLayout>
  <header id="hero" class="hero-section">
    <div class="container hero-container">
      <div class="hero-content">
        <div class="badge" data-hero-reveal>{t('home.badge')}</div>
        <h1 data-hero-reveal>{t('home.heroTitle')} <span class="highlight">{t('home.heroTitleAccent')}</span></h1>
        <p data-hero-reveal>{t('home.heroDesc')}</p>
        <div class="hero-buttons" data-hero-reveal>
          <a href={designPath} class="btn btn-primary">{t('btn.tryDesigner')}</a>
          <a href={productsPath} class="btn btn-secondary">{t('btn.explore')}</a>
        </div>
        <div class="stats" data-hero-reveal>
          <div class="stat-item"><span class="stat-value">{t('home.stat1Value')}</span><span class="stat-label">{t('home.stat1Label')}</span></div>
          <div class="stat-item"><span class="stat-value">{t('home.stat2Value')}</span><span class="stat-label">{t('home.stat2Label')}</span></div>
        </div>
      </div>
      <div class="hero-card-wrapper" data-hero-reveal>
        <div class="ai-card">
          <div class="card-header"><i data-lucide="bot"></i><h3>{t('cfg.title')}</h3></div>
          <div class="input-details">
            <div class="detail-item"><span class="label">{t('cfg.spaceType')}</span><span class="value">{t('cfg.space.balcony')}</span></div>
            <div class="detail-item"><span class="label">{t('cfg.sunlight')}</span><span class="value">{t('cfg.sun.partial')}</span></div>
            <div class="detail-item"><span class="label">{t('cfg.goal')}</span><span class="value">{t('cfg.goal.vegetables')}</span></div>
          </div>
          <a href={designPath} class="btn btn-primary full-width"><i data-lucide="sparkles"></i> {t('btn.generate')}</a>
        </div>
      </div>
    </div>
  </header>

  <section id="problem" class="section--surface">
    <div class="container">
      <SectionHeader title={t('home.problemTitle')} subtitle={t('home.problemSubtitle')} />
      <div class="grid grid-3">
        {problems.map((p) => (
          <div class="feature-card">
            <div class="icon-wrapper"><i data-lucide={p.icon}></i></div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="products">
    <div class="container">
      <SectionHeader title={t('home.productsTitle')} subtitle={t('products.subtitle')} />
      <div class="grid grid-3">
        {products.map((p) => <ProductCard product={p} />)}
      </div>
    </div>
  </section>

  <section class="benefits-section">
    <div class="container">
      <SectionHeader title={t('home.benefitsTitle')} />
      <div class="benefits-grid">
        {benefits.map((b) => (
          <div class="benefit-item">
            <div class="b-icon"><i data-lucide={b.icon}></i></div>
            <h4>{b.title}</h4>
            <p>{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section--surface">
    <div class="container">
      <SectionHeader title={t('home.testimonialsTitle')} />
      <div class="grid grid-3">
        {testimonials.map((tm) => (
          <div class="testimonial-card">
            <div class="stars"><i data-lucide="star"></i><i data-lucide="star"></i><i data-lucide="star"></i><i data-lucide="star"></i><i data-lucide="star"></i></div>
            <p class="quote">{tm.quote}</p>
            <div class="author">
              <div class="avatar">{tm.initial}</div>
              <div class="author-info"><h5>{tm.name}</h5><span>{tm.role}</span></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container text-center">
      <h2>{t('home.ctaTitle')}</h2>
      <p>{t('home.ctaDesc')}</p>
      <a href={designPath} class="btn btn-secondary btn-large">{t('btn.tryDesigner')}</a>
    </div>
  </section>
</BaseLayout>
