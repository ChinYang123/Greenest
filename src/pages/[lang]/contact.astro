---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import MockForm from '../../components/MockForm.astro';
import { getLangFromUrl, useTranslations, langStaticPaths } from '../../i18n/utils';

export const getStaticPaths = langStaticPaths;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const fields = [
  { name: 'name', label: t('form.name'), type: 'text' as const, required: true },
  { name: 'email', label: t('form.email'), type: 'email' as const, required: true },
  { name: 'message', label: t('form.message'), type: 'textarea' as const, required: true },
];
---
<BaseLayout title={t('contact.title')} description={t('contact.subtitle')}>
  <PageHeader title={t('contact.title')} subtitle={t('contact.subtitle')} />
  <section>
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <div class="item"><i data-lucide="mail"></i><div><h4>{t('contact.email')}</h4><p>chiachinyang@gmail.com</p></div></div>
          <div class="item"><i data-lucide="phone"></i><div><h4>{t('contact.phone')}</h4><p>+60 16-808 6302</p></div></div>
          <div class="item"><i data-lucide="map-pin"></i><div><h4>{t('contact.address')}</h4><p>{t('contact.addressValue')}</p></div></div>
        </div>
        <MockForm fields={fields} submitLabel={t('btn.send')} />
      </div>
    </div>
  </section>
</BaseLayout>
