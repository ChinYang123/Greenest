---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, langStaticPaths } from '../../i18n/utils';
import { products } from '../../data/products';
import ProductCard from '../../components/ProductCard.astro';

export const getStaticPaths = langStaticPaths;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const features = [
  { icon: 'layers', title: t('vertical.f1Title'), desc: t('vertical.f1Desc') },
  { icon: 'droplet', title: t('vertical.f2Title'), desc: t('vertical.f2Desc') },
  { icon: 'sprout', title: t('vertical.f3Title'), desc: t('vertical.f3Desc') },
];
const kits = products.filter((p) => p.fits.includes('balcony'));
---
<BaseLayout title={t('vertical.title')} description={t('vertical.subtitle')}>
  <PageHeader title={t('vertical.title')} subtitle={t('vertical.subtitle')} />
  <section>
    <div class="container">
      <div class="grid grid-3">
        {features.map((f) => (
          <div class="feature-card">
            <div class="icon-wrapper"><i data-lucide={f.icon}></i></div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="section--surface">
    <div class="container">
      <div class="grid grid-2" style="max-width:760px;margin:0 auto;">
        {kits.map((p) => <ProductCard product={p} />)}
      </div>
      <div class="text-center" style="margin-top:3rem;">
        <a href={getLocalizedPath('/design-your-garden', lang)} class="btn btn-primary btn-large">{t('btn.tryDesigner')}</a>
      </div>
    </div>
  </section>
</BaseLayout>
