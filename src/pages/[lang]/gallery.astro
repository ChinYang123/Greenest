---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getLangFromUrl, useTranslations, langStaticPaths } from '../../i18n/utils';

export const getStaticPaths = langStaticPaths;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// On-palette gradients (forest / sage / clay) so the gallery sits in the
// same botanical-editorial world as the rest of the site.
const FOREST = 'linear-gradient(150deg,#2F6B45,#143D26)';
const PINE = 'linear-gradient(150deg,#21603C,#0F3320)';
const SAGE = 'linear-gradient(150deg,#3E8E5A,#21603C)';
const CLAY = 'linear-gradient(150deg,#C2674A,#8A3F2B)';
const labels = lang === 'zh'
  ? ['阳台垂直花园概念', '阳台菜园概念', '咖啡馆屋顶香草园概念', '社区花圃概念', '室内香草角概念', '屋顶花卉区概念', '小空间叶菜种植概念', '办公室绿化墙概念', '热带花墙概念']
  : ['Balcony vertical garden concept', 'Balcony veggie patch concept', 'Café rooftop herb garden concept', 'Community flower bed concept', 'Indoor herb corner concept', 'Rooftop flower zone concept', 'Small-space leafy greens concept', 'Office green wall concept', 'Tropical flowering wall concept'];
const emojis = ['🪴', '🍅', '☕', '🌸', '🌿', '🌻', '🥬', '🫚', '🌺'];
const gradients = [FOREST, SAGE, PINE, CLAY, SAGE, FOREST, PINE, FOREST, CLAY];
const items = emojis.map((emoji, i) => ({ emoji, label: labels[i], c: gradients[i] }));
---
<BaseLayout title={t('gallery.title')} description={t('gallery.subtitle')}>
  <PageHeader title={t('gallery.title')} subtitle={t('gallery.subtitle')} />
  <section>
    <div class="container">
      <div class="gallery-grid">
        {items.map((it) => (
          <div class="gallery-item" style={`background:${it.c}`}>
            <span class="plate-motif" aria-hidden="true">{it.emoji}</span>
            <span class="label">{it.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
