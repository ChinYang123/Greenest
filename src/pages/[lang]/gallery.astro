---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getLangFromUrl, useTranslations, langStaticPaths } from '../../i18n/utils';

export const getStaticPaths = langStaticPaths;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const items = lang === 'zh'
  ? [
      { emoji: '🪴', label: '阳台垂直花园概念', c: 'linear-gradient(135deg,#2E7D32,#1B5E20)' },
      { emoji: '🍅', label: '阳台菜园概念', c: 'linear-gradient(135deg,#388E3C,#1B5E20)' },
      { emoji: '☕', label: '咖啡馆屋顶香草园概念', c: 'linear-gradient(135deg,#1B5E20,#2E7D32)' },
      { emoji: '🌸', label: '社区花圃概念', c: 'linear-gradient(135deg,#43A047,#2E7D32)' },
      { emoji: '🌿', label: '室内香草角概念', c: 'linear-gradient(135deg,#2E7D32,#388E3C)' },
      { emoji: '🌻', label: '屋顶花卉区概念', c: 'linear-gradient(135deg,#33691E,#1B5E20)' },
      { emoji: '🥬', label: '小空间叶菜种植概念', c: 'linear-gradient(135deg,#1B5E20,#33691E)' },
      { emoji: '🫚', label: '办公室绿化墙概念', c: 'linear-gradient(135deg,#2E7D32,#1B5E20)' },
      { emoji: '🌺', label: '热带花墙概念', c: 'linear-gradient(135deg,#388E3C,#2E7D32)' },
    ]
  : [
      { emoji: '🪴', label: 'Balcony vertical garden concept', c: 'linear-gradient(135deg,#2E7D32,#1B5E20)' },
      { emoji: '🍅', label: 'Balcony veggie patch concept', c: 'linear-gradient(135deg,#388E3C,#1B5E20)' },
      { emoji: '☕', label: 'Café rooftop herb garden concept', c: 'linear-gradient(135deg,#1B5E20,#2E7D32)' },
      { emoji: '🌸', label: 'Community flower bed concept', c: 'linear-gradient(135deg,#43A047,#2E7D32)' },
      { emoji: '🌿', label: 'Indoor herb corner concept', c: 'linear-gradient(135deg,#2E7D32,#388E3C)' },
      { emoji: '🌻', label: 'Rooftop flower zone concept', c: 'linear-gradient(135deg,#33691E,#1B5E20)' },
      { emoji: '🥬', label: 'Small-space leafy greens concept', c: 'linear-gradient(135deg,#1B5E20,#33691E)' },
      { emoji: '🫚', label: 'Office green wall concept', c: 'linear-gradient(135deg,#2E7D32,#1B5E20)' },
      { emoji: '🌺', label: 'Tropical flowering wall concept', c: 'linear-gradient(135deg,#388E3C,#2E7D32)' },
    ];
---
<BaseLayout title={t('gallery.title')} description={t('gallery.subtitle')}>
  <PageHeader title={t('gallery.title')} subtitle={t('gallery.subtitle')} />
  <section>
    <div class="container">
      <div class="gallery-grid">
        {items.map((it) => (
          <div class="gallery-item" style={`background:${it.c}`}>
            {it.emoji}
            <span class="label">{it.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
