---
// Roof Garden Service has been merged into the Garden Designer page.
// Keep this URL working (older links / blog posts point here) by redirecting.
import { langStaticPaths, getLangFromUrl } from '../../i18n/utils';
export const getStaticPaths = langStaticPaths;
const lang = getLangFromUrl(Astro.url);
const target = `/${lang}/design-your-garden`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting…</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>Garden Designer</a>…</p>
  </body>
</html>
