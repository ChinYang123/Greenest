---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import GardenDesigner from '../../components/garden-designer/GardenDesigner.astro';
import MockForm from '../../components/MockForm.astro';
import { getLangFromUrl, useTranslations, langStaticPaths } from '../../i18n/utils';

export const getStaticPaths = langStaticPaths;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Roof-garden service content, merged into this page.
const steps = [
  { n: 1, title: t('roof.step1'), desc: t('roof.step1Desc') },
  { n: 2, title: t('roof.step2'), desc: t('roof.step2Desc') },
  { n: 3, title: t('roof.step3'), desc: t('roof.step3Desc') },
];
const fields = [
  { name: 'name', label: t('form.name'), type: 'text' as const, required: true },
  { name: 'email', label: t('form.email'), type: 'email' as const, required: true },
  { name: 'phone', label: t('form.phone'), type: 'tel' as const, required: false },
  { name: 'spaceType', label: t('form.spaceType'), type: 'select' as const, required: true, options: [t('cfg.space.rooftop'), t('cfg.space.balcony'), t('cfg.space.indoor')] },
  { name: 'message', label: t('form.message'), type: 'textarea' as const, required: false },
];
---
<BaseLayout title={t('cfg.title')} description={t('cfg.subtitle')}>
  <PageHeader title={t('cfg.title')} subtitle={t('cfg.subtitle')} />

  <section>
    <div class="container">
      <GardenDesigner />
    </div>
  </section>

  <!-- Roof Garden Service (merged) -->
  <section class="section--surface">
    <div class="container">
      <SectionHeader title={t('roof.title')} subtitle={t('roof.subtitle')} />
      <div class="steps-grid">
        {steps.map((s) => (
          <div class="step-card">
            <div class="step-num">{s.n}</div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <SectionHeader title={t('roof.formTitle')} />
      <MockForm fields={fields} submitLabel={t('btn.submit')} />
    </div>
  </section>
</BaseLayout>
